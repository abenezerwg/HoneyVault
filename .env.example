# Auth0 Configuration
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Auth0 Machine-to-Machine (for Token Vault API access)
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_AUDIENCE=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# PostgreSQL (Railway or local)
DATABASE_URL=

# App settings
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Webhook verification (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=replace_with_random_hex_secret

# ngrok tunnel URL (dev only - run: npx ngrok http 3001)
NGROK_URL=https://your-ngrok-id.ngrok.io

# JWT secret for internal service tokens
JWT_SECRET=replace_with_another_random_secret
